#!/usr/bin/env bash
# brewfile-sync — dump current brew state and write the host overlay
# (everything not already in the base Brewfile) to Brewfile.<friendly-name>.
#
# Usage: brewfile-sync [friendly-name]
#   With no argument, the friendly name is derived from LocalHostName
#   via the host_to_friendly() mapping. Edit that function when adding
#   or renaming machines.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOTFILES_DIR="$(dirname "$SCRIPT_DIR")"
BASE_BREWFILE="$DOTFILES_DIR/Brewfile"

if [[ ! -f "$BASE_BREWFILE" ]]; then
  echo "brewfile-sync: base Brewfile not found at $BASE_BREWFILE" >&2
  exit 1
fi

host_to_friendly() {
  case "$(echo "$1" | tr '[:upper:]' '[:lower:]')" in
    jiggymini)     echo "jiggymini" ;;
    jiggybook-pro) echo "jiggybook" ;;
    jiggybook-air) echo "jiggyair"  ;;
    # TODO: add JiggyBook Pro XVI.3 when it arrives (July 2026)
    *)             echo ""          ;;
  esac
}

if [[ ${#} -gt 0 ]]; then
  FRIENDLY="$1"
else
  LOCAL_HOST="$(scutil --get LocalHostName)"
  FRIENDLY="$(host_to_friendly "$LOCAL_HOST")"
  if [[ -z "$FRIENDLY" ]]; then
    echo "brewfile-sync: no friendly-name mapping for LocalHostName '$LOCAL_HOST'" >&2
    echo "  edit host_to_friendly() in $0, or pass a name explicitly:" >&2
    echo "    brewfile-sync <friendly-name>" >&2
    exit 1
  fi
fi

# Validate friendly name is a safe path component — it becomes Brewfile.$FRIENDLY.
if [[ ! "$FRIENDLY" =~ ^[A-Za-z0-9._-]+$ ]]; then
  echo "brewfile-sync: invalid friendly name '$FRIENDLY' (allowed: A-Za-z0-9._-)" >&2
  exit 1
fi

OVERLAY_FILE="$DOTFILES_DIR/Brewfile.$FRIENDLY"
TMP_FULL="$(mktemp "${TMPDIR:-/tmp}/brewfile-sync.XXXXXXXXXX")"
BASE_STRIPPED="$(mktemp "${TMPDIR:-/tmp}/brewfile-sync-base.XXXXXXXXXX")"
trap 'rm -f "$TMP_FULL" "$BASE_STRIPPED"' EXIT INT TERM HUP

# --vscode alone is exclusive, so list every category we care about.
brew bundle dump --force --file="$TMP_FULL" \
  --taps --formula --cask --mas --vscode

# Strip comments and blank lines from the base before matching, so a
# commented line like `cask "setapp" # notes` still filters out the
# uncommented `cask "setapp"` line from the dump.
sed -E \
  -e 's/[[:space:]]*#.*$//' \
  -e 's/[[:space:]]+$//' \
  -e '/^[[:space:]]*$/d' \
  "$BASE_BREWFILE" > "$BASE_STRIPPED"

# Overlay = dump lines not present in the stripped base.
# grep -Fxv preserves the dump's original order (taps → formulas → casks → mas → vscode).
# grep exit 1 = no matches survived (overlay empty, expected). Anything else is a real error.
set +e
grep -Fxv -f "$BASE_STRIPPED" "$TMP_FULL" > "$OVERLAY_FILE"
grep_status=$?
set -e
if [[ $grep_status -ne 0 && $grep_status -ne 1 ]]; then
  echo "brewfile-sync: grep failed with status $grep_status" >&2
  exit $grep_status
fi

FULL_COUNT=$(grep -cv '^[[:space:]]*$' "$TMP_FULL" || true)
OVERLAY_COUNT=$(grep -cv '^[[:space:]]*$' "$OVERLAY_FILE" || true)

echo "brewfile-sync: $FRIENDLY"
echo "  dump:    $FULL_COUNT lines"

# If the overlay came out empty, remove it rather than leaving a no-op file
# that setup.sh will still try to brew-bundle-install.
if [[ ! -s "$OVERLAY_FILE" ]]; then
  rm -f "$OVERLAY_FILE"
  echo "  overlay: 0 lines (machine matches base — $OVERLAY_FILE removed)"
else
  echo "  overlay: $OVERLAY_COUNT lines -> $OVERLAY_FILE"
fi
