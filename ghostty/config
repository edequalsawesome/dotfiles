# The syntax is "key = value". The whitespace around the
# equals doesn't matter.

# COLORS
# background = E67F0D
# foreground = ffffff

# THEMES
theme = Catppuccin Mocha

# FONTS
font-family = "Hack Nerd Font Mono"
font-size = 16

# PADDING
window-padding-x = 10
keybind = shift+enter=text:\n

# COPY ON SELECT
copy-on-select = clipboard

# Pass Cmd+T and Cmd+O through to Zellij so the project-sidebar plugin's
# new-tab-with-sidebar and toggle-sidebar-focus bindings work.
keybind = cmd+t=unbind
keybind = cmd+o=unbind