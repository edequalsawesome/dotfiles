{
  "env": {
    "PAGESPEED_API_KEY": "YOUR_PAGESPEED_API_KEY_HERE"
  },
  "permissions": {
    "allow": [
      "Bash(cp:*)",
      "Bash(curl:*)",
      "Bash(cat:*)",
      "Bash(mkdir:*)",
      "Bash(ls:*)",
      "Bash(test:*)",
      "Bash(source:*)",
      "Bash(aerospace:*)",
      "Bash(td add:*)",
      "WebFetch(domain:getmoshi.app)",
      "WebFetch(domain:mrmurphy.dev)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "mcp__quill__search_meetings",
      "mcp__quill__get_meeting",
      "mcp__quill__get_minutes",
      "mcp__quill__get_transcript",
      "Skill(claudeception)",
      "Read(~/.claude/**)",
      "Edit(~/.claude/**)",
      "Write(~/.claude/**)",
      "Read(~/Obsidian/**)",
      "Edit(~/Obsidian/**)",
      "Write(~/Obsidian/**)",
      "Read(~/Claude/**)",
      "Edit(~/Claude/**)",
      "Write(~/Claude/**)",
      "Read(~/.config/**)",
      "Edit(~/.config/**)",
      "Write(~/.config/**)",
      "Read(~/Development/**)",
      "Edit(~/Development/**)",
      "Write(~/Development/**)",
      "Read(~/dotfiles/**)",
      "Edit(~/dotfiles/**)",
      "Write(~/dotfiles/**)",
      "Read(~/Downloads/**)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/uv run ~/.claude/hooks/claude-island-state.py"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/uv run ~/.claude/hooks/claude-island-state.py",
            "timeout": 86400
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/uv run ~/.claude/hooks/claude-island-state.py"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/uv run ~/.claude/hooks/claude-island-state.py"
          }
        ]
      },
      {
        "matcher": "manual",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/uv run ~/.claude/hooks/claude-island-state.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/uv run ~/.claude/hooks/claude-island-state.py"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/uv run ~/.claude/hooks/claude-island-state.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/uv run ~/.claude/hooks/claude-island-state.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/uv run ~/.claude/hooks/claude-island-state.py"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/uv run ~/.claude/hooks/claude-island-state.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/claudeception-activator.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-doc-reminder.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/uv run ~/.claude/hooks/claude-island-state.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c 'plugin_dir=$(ls -d \"$HOME\"/.claude/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | awk -F/ '\"'\"'{ print $(NF-1) \"\\t\" $0 }'\"'\"' | sort -t. -k1,1n -k2,2n -k3,3n -k4,4n | tail -1 | cut -f2-); exec \"$(command -v bun 2>/dev/null || command -v node)\" \"${plugin_dir}src/index.ts\"'"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "linear@claude-plugins-official": true,
    "obsidian@obsidian-skills": true,
    "claude-hud@claude-hud": true
  },
  "extraKnownMarketplaces": {
    "claude-code-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-code"
      }
    },
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    }
  }
}
