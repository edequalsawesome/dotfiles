// Vertical tabs layout — use with: zellij --layout vertical
// Tab sidebar on the left of every tab, built-in status bar on bottom.
layout {
    default_tab_template {
        pane split_direction="vertical" {
            pane size=20 borderless=true {
                plugin location="vertical-tabs"
            }
            children
        }
        pane size=2 borderless=true {
            plugin location="status-bar"
        }
    }

    tab focus=true {
        pane
    }
}
