// Project sidebar layout — uses AndrewBeniston/zellij-project-sidebar.
// The plugin registers Cmd+T globally so EVERY new tab includes the
// sidebar (unlike cfal/zellij-vertical-tabs). Cmd+O toggles focus to
// the sidebar. Requires Ghostty to pass Cmd+T and Cmd+O through —
// configured via `keybind = cmd+t=unbind` / `cmd+o=unbind` in the
// Ghostty config.
layout {
    pane split_direction="vertical" {
        pane size=20 borderless=true name="Projects" {
            plugin location="file:~/.config/zellij/plugins/zellij-project-sidebar.wasm" {
                scan_dir "/Users/edequalsawesome/Development"
                session_layout "/Users/edequalsawesome/.config/zellij/layouts/vertical.kdl"
            }
        }
        pane
    }
    pane size=2 borderless=true {
        plugin location="status-bar"
    }
}
